###############################################################################
# Terraform
###############################################################################

# Local .terraform directories
**/.terraform/*

# Terraform state
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

###############################################################################
# Variable files (often contain secrets)
###############################################################################

*.tfvars
*.tfvars.json

###############################################################################
# CLI configuration
###############################################################################

.terraformrc
terraform.rc

###############################################################################
# Plan files
###############################################################################

*.tfplan
*.plan

###############################################################################
# Sensitive files
###############################################################################

*.pem
*.key
*.pfx
*.p12

###############################################################################
# IDE
###############################################################################

.vscode/
.idea/

###############################################################################
# OS files
###############################################################################

.DS_Store
Thumbs.db

###############################################################################
# Logs
###############################################################################

*.log
